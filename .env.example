# Eco-Agent 環境變數範本（§6 / §4.4.4）
#
# 用法：複製為 .env 並填入實際值；.env 已列入 .gitignore，切勿提交版控。
# 各語言/工具載入 .env 方式不一；本專案於 shell 以 `export $(grep -v '^#' .env | xargs)`
# 或由 IDE/執行環境注入。程式一律讀「環境變數」，不直接讀 .env 檔。

# ─────────────────────────────────────────────────────────────────────────────
# 路徑 C：Google Drive API v3（§6，真串，TODO(secrets)：勿硬編碼、勿提交版控）
# ─────────────────────────────────────────────────────────────────────────────

# OAuth 2.0 用戶端憑證（Google Cloud Console → APIs & Services → Credentials →
# OAuth client ID，類型選「Desktop app」）。
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# refresh token 落地路徑（可選）。未設時預設為使用者設定目錄下
# eco-agent/google_oauth_token.json（Windows: %AppData%、macOS: ~/Library/Application Support）。
# 首次執行 `go run ./cmd/drive-demo authorize` 完成授權後於此落地。
# GOOGLE_OAUTH_TOKEN_PATH=

# 授權範圍固定為只讀 metadata（程式內建，無需設定，僅備註）：
#   https://www.googleapis.com/auth/drive.metadata.readonly

# ─────────────────────────────────────────────────────────────────────────────
# 路徑 B：個人專屬印表機 SNMP（§2 Step 3）
# ─────────────────────────────────────────────────────────────────────────────

# 印表機 IP 或主機名。未設定即視為「本機無個人專屬印表機」，路徑 B 優雅降級跳過。
# 需與印表機同網段且對方開啟 SNMP v2c（UDP 161）。
# ECO_AGENT_PRINTER_HOST=192.168.1.50

# SNMP v2c 唯讀 community（可選，預設 public）。
# ECO_AGENT_PRINTER_COMMUNITY=public

# SNMP 埠（可選，預設 161）。
# ECO_AGENT_PRINTER_PORT=161

# page counter 的 instance OID（可選，預設 1.3.6.1.2.1.43.10.2.1.4.1.1，
# 即 prtMarkerLifeCount.1.1）。index 非 1.1 的機種可在此覆寫；未覆寫時程式查不到會
# 自動巡走 prtMarkerLifeCount 欄取第一筆。
# ECO_AGENT_PRINTER_OID=1.3.6.1.2.1.43.10.2.1.4.1.1

# ─────────────────────────────────────────────────────────────────────────────
# 共用：配置 profile（§4.4.4）
# ─────────────────────────────────────────────────────────────────────────────

# 一鍵切換正式／測試值：設為 testing 走大幅縮短的時間類參數，數分鐘內觀察完整流程。
# ECO_AGENT_PROFILE=testing

# 上傳 mock 端點（§7）。未設時各 demo 內建 in-process mock。
# ECO_AGENT_UPLOAD_URL=http://localhost:8080/mock/ingest
